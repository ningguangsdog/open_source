{
  "name": "adobe_acrobat_deep",
  "description": "Focused native deep probe for Adobe Acrobat Android research samples.",
  "schema_version": "2026-07-07.native-probe-profile.v1",
  "priority_libraries": [
    "libMagicClean.so",
    "libOCRCore.so",
    "libPDFLOCRLib.so",
    "libidrsocr16.so",
    "libidrskrn16.so",
    "libidrsprepro16.so",
    "libColoradoMobile.so",
    "libpage_segmentation_tflite.so",
    "libimage_processing_util_jni.so",
    "libAdobeReader.so",
    "libBIB.so",
    "libBIBUtils.so"
  ],
  "deprioritize_libraries": [
    "libmediapipe",
    "libtensorflowlite",
    "libopencv",
    "libc++",
    "libfbjni",
    "libprotobuf",
    "libgrpc",
    "libskia"
  ],
  "seed_name_patterns": [
    "MagicClean",
    "CameraClean",
    "cropAndClean",
    "getCorners",
    "preLoad",
    "Dewarp",
    "Warp",
    "Clean",
    "Detect",
    "OCRCore",
    "OCR",
    "PDFOCR",
    "DoOCRE",
    "DoWarpDetection",
    "SetOutputType",
    "SetResourceDirectory",
    "SetCompressors",
    "getCompressorPtr",
    "getCTGlyphDataHandler",
    "Glyph",
    "BIB",
    "idrs",
    "CNPDF",
    "ConvertToCNPDF",
    "CMColorado",
    "Colorado",
    "PageSegmentation",
    "TFLitePageSegmentation",
    "PageSegmentationRunner",
    "GetRunnerImpl",
    "reset",
    "image_processing",
    "YUV",
    "Bitmap",
    "PDEImage",
    "Rasterize",
    "Render"
  ],
  "generic_helper_patterns": [
    "std::",
    "__cxx",
    "__gnu",
    "operator new",
    "operator delete",
    "callMethod",
    "CObjectArray",
    "JNIEnv",
    "jobjectArray",
    "AAssetManager"
  ],
  "capability_priorities": [
    "document_pdf",
    "ocr",
    "document_scan",
    "image_processing",
    "local_ml",
    "compression",
    "crypto"
  ],
  "default_feature_detail": "pseudocode",
  "default_limits": {
    "max_seed_targets": 80,
    "max_decompile_targets": 24,
    "max_libraries": 6,
    "timeout_per_function": 60,
    "timeout_per_app": 3600,
    "expansion_rounds": 1,
    "max_expanded_targets": 8
  }
}
